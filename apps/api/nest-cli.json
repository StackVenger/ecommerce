{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": "swc",
    "typeCheck": false,
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.build.json",
    "assets": [{ "include": "email/templates/**/*.hbs", "outDir": "dist" }],
    "watchAssets": true
  },
  "generateOptions": {
    "spec": true,
    "flat": false
  }
}
